{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kennedy-smith-mechanical",
  "compatibility_date": "2026-04-25",
  "main": "_worker.js",
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
